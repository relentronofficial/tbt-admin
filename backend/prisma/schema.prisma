generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- ENUMS ---

enum Role {
  super_admin
  admin
  account_manager
  mentor
  moderator
}

enum AdminStatus {
  active
  inactive
  suspended
  pending_approval
}

enum MemberStatus {
  active
  inactive
  paused
  suspended
}

enum VerificationStatus {
  awaiting_kyc
  under_review
  verified
  rejected
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum AccessType {
  free
  subscription
  premium
}

enum CourseStatus {
  draft
  published
  archived
}

enum ContentType {
  video
  audio
  pdf
  ebook
  text
}

enum Priority {
  low
  medium
  high
  critical
}

enum SubmissionStatus {
  pending
  approved
  rejected
  resubmission_required
}

enum PostType {
  post
  announcement
  poll
}

enum WebinarStatus {
  scheduled
  live
  ended
}

enum NotificationType {
  system
  course
  task
  community
  webinar
}

enum TicketStatus {
  open
  in_progress
  escalated
  resolved
  closed
}

enum SenderType {
  member
  admin
}

enum Gender {
  male
  female
  other
  prefer_not_to_say
}

enum SessionMode {
  online
  offline
  hybrid
}

enum BusinessStage {
  idea
  startup
  growth
  scaling
}

enum MembershipPlan {
  free
  starter
  premium
  vip
  enterprise
}

enum ChurnRisk {
  low
  medium
  high
}

// --- MODELS ---

model AdminIdSequence {
  id Int @id @default(autoincrement())
}

model Admin {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId            String      @unique @map("clerk_id")
  fullName           String      @map("full_name")
  email              String      @unique
  phone              String?
  alternatePhone     String?     @map("alternate_phone")
  dob                DateTime?   @db.Date
  bloodGroup         String?     @map("blood_group")
  profilePhotoUrl    String?     @map("profile_photo_url")
  role               Role
  department         String?
  designation        String?
  reportingManagerId String?     @map("reporting_manager_id") @db.Uuid
  employeeId         String?     @unique @map("employee_id")
  country            String?     @default("India")
  state              String?
  city               String?
  address            String?
  status             AdminStatus @default(active)
  username           String?     @unique
  notes              String?
  tags               String[]
  permissions        Json?
  lastLoginAt        DateTime?   @map("last_login_at") @db.Timestamptz(6)

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  reportingManager Admin?  @relation("ManagerToAdmin", fields: [reportingManagerId], references: [id])
  subordinates     Admin[] @relation("ManagerToAdmin")

  assignedMembers Member[] @relation("AccountManager")
  createdMembers  Member[] @relation("MemberCreator")

  courses         Course[]         @relation("CourseCreator")
  reviewedTasks   TaskSubmission[] @relation("TaskReviewer")
  hostedWebinars  Webinar[]        @relation("WebinarHost")
  assignedTickets SupportTicket[]  @relation("TicketAssignee")
  auditLogs       AuditLog[]
  resources       Resource[]
  updatedSettings Setting[]        @relation("SettingUpdater")

  @@map("admins")
}

model Member {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId              String             @unique @map("member_id")
  firstName             String             @map("first_name")
  lastName              String?            @map("last_name")
  email                 String             @unique
  phone                 String             @unique
  alternatePhone        String?            @map("alternate_phone")
  dob                   DateTime?          @db.Date
  gender                Gender?
  profilePhotoUrl       String?            @map("profile_photo_url")
  city                  String?
  state                 String?
  pincode               String?
  businessName          String?            @map("business_name")
  businessEstablishedOn DateTime?          @map("business_established_on") @db.Date
  productServiceType    String?            @map("product_service_type")
  instagramLink         String?            @map("instagram_link")
  annualTurnover        String?            @map("annual_turnover")
  goalAfter90Days       String?            @map("goal_after_90_days")
  preferredSessionMode  SessionMode?       @map("preferred_session_mode")
  gstNumber             String?            @map("gst_number")
  marketingChannels     String[]           @map("marketing_channels")
  marketingChannelName  String?            @map("marketing_channel_name")
  hasMarketingTeam      Boolean            @default(false) @map("has_marketing_team")
  marketingTeamDetails  String?            @map("marketing_team_details")
  hasVideoEditing       Boolean            @default(false) @map("has_video_editing")
  videoEditingDetails   String?            @map("video_editing_details")
  domainHostingDetails  String?            @map("domain_hosting_details")
  businessAddress       String?            @map("business_address")
  sector                String?
  industry              String?
  subIndustry           String?            @map("sub_industry")
  businessStage         BusinessStage?     @map("business_stage")
  currentChallenges     String[]           @map("current_challenges")
  notes                 String?
  membershipPlan        MembershipPlan     @default(free) @map("membership_plan")
  status                MemberStatus       @default(active)
  verificationStatus    VerificationStatus @default(awaiting_kyc) @map("verification_status")
  accountManagerId      String?            @map("account_manager_id") @db.Uuid
  batchId               String?            @map("batch_id") @db.Uuid
  pushToken             String?            @map("push_token")
  healthScore           Int                @default(0) @map("health_score")
  churnRisk             ChurnRisk          @default(low) @map("churn_risk")
  totalPoints           Int                @default(0) @map("total_points")
  currentStreak         Int                @default(0) @map("current_streak")
  longestStreak         Int                @default(0) @map("longest_streak")
  lastActiveAt          DateTime?          @map("last_active_at") @db.Timestamptz(6)
  onboardingCompleted   Boolean            @default(false) @map("onboarding_completed")

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  accountManager Admin? @relation("AccountManager", fields: [accountManagerId], references: [id])
  creator        Admin? @relation("MemberCreator", fields: [createdBy], references: [id])
  batch          Batch? @relation(fields: [batchId], references: [id])

  courseEnrollments    CourseEnrollment[]
  quizAttempts         QuizAttempt[]
  lessonProgress       LessonProgress[]
  programEnrollments   ProgramEnrollment[]
  taskSubmissions      TaskSubmission[]
  podcastProgress      PodcastProgress[]
  webinarRegistrations WebinarRegistration[]
  eventRegistrations   EventRegistration[]
  posts                Post[]
  comments             Comment[]
  likes                Like[]
  supportTickets       SupportTicket[]
  rewardRedemptions    RewardRedemption[]
  badges               MemberBadge[]
  milestones           MemberMilestone[]
  streaks              Streak[]
  pointsLedger         PointsLedger[]
  subscriptions        Subscription[]
  payments             Payment[]
  kycDocuments         KycDocument[]
  activityLogs         ActivityLog[]
  sessions             MemberSession[]
  whatsappMessages     WhatsappMessage[]
  assessments          Assessment[]
  checklistCompletions ChecklistCompletion[]
  pollVotes            PollVote[]
  leaderboardEntries   Leaderboard[]
  Notification         Notification[]

  @@map("members")
}

model Course {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title         String
  slug          String       @unique
  description   String?
  thumbnailUrl  String?      @map("thumbnail_url")
  trailerUrl    String?      @map("trailer_url")
  categoryId    String?      @map("category_id") @db.Uuid
  level         CourseLevel  @default(beginner)
  accessType    AccessType   @default(free) @map("access_type")
  price         Decimal?     @db.Decimal(10, 2)
  durationHours Decimal?     @map("duration_hours") @db.Decimal(5, 1)
  totalModules  Int          @default(0) @map("total_modules")
  totalLessons  Int          @default(0) @map("total_lessons")
  sortOrder     Int          @default(0) @map("sort_order")
  isPublished   Boolean      @default(false) @map("is_published")
  isFeatured    Boolean      @default(false) @map("is_featured")
  status        CourseStatus @default(draft)

  createdBy String?   @map("created_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  category    Category?          @relation(fields: [categoryId], references: [id])
  creator     Admin?             @relation("CourseCreator", fields: [createdBy], references: [id])
  modules     Module[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model Module {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId      String   @map("course_id") @db.Uuid
  title         String
  description   String?
  introVideoUrl String?  @map("intro_video_url")
  sortOrder     Int      @default(0) @map("sort_order")
  isPublished   Boolean  @default(false) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("modules")
}

model Lesson {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId        String      @map("module_id") @db.Uuid
  title           String
  description     String?
  contentType     ContentType @map("content_type")
  contentUrl      String?     @map("content_url")
  durationMinutes Int?        @map("duration_minutes")
  sortOrder       Int         @default(0) @map("sort_order")
  isLocked        Boolean     @default(true) @map("is_locked")
  quizRequired    Boolean     @default(true) @map("quiz_required")
  passPercentage  Int         @default(70) @map("pass_percentage")
  isPublished     Boolean     @default(false) @map("is_published")
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  module   Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz     Quiz?
  progress LessonProgress[]

  @@map("lessons")
}

model Quiz {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId       String   @unique @map("lesson_id") @db.Uuid
  title          String
  passPercentage Int      @default(70) @map("pass_percentage")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  lesson    Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId        String   @map("quiz_id") @db.Uuid
  questionText  String   @map("question_text")
  questionType  String   @map("question_type")
  options       Json?
  correctAnswer String   @map("correct_answer")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model QuizAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId    String   @map("member_id") @db.Uuid
  quizId      String   @map("quiz_id") @db.Uuid
  score       Int
  passed      Boolean
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model LessonProgress {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId        String    @map("member_id") @db.Uuid
  lessonId        String    @map("lesson_id") @db.Uuid
  watchPercentage Int       @default(0) @map("watch_percentage")
  completed       Boolean   @default(false)
  completedAt     DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([memberId, lessonId])
  @@map("lesson_progress")
}

model CourseEnrollment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId           String    @map("member_id") @db.Uuid
  courseId           String    @map("course_id") @db.Uuid
  enrolledAt         DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  completedAt        DateTime? @map("completed_at") @db.Timestamptz(6)
  progressPercentage Int       @default(0) @map("progress_percentage")

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([memberId, courseId])
  @@map("course_enrollments")
}

model Program {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  description    String?
  durationDays   Int      @map("duration_days")
  incubationDays Int      @default(0) @map("incubation_days")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  enrollments ProgramEnrollment[]
  steps       TaskStep[]
  tasks       Task[]
  batches     Batch[]
  assessments Assessment[]
  checklists  Checklist[]
  Milestone   Milestone[]

  @@map("programs")
}

model ProgramEnrollment {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId    String    @map("member_id") @db.Uuid
  programId   String    @map("program_id") @db.Uuid
  enrolledAt  DateTime  @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  startedAt   DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  status      String    @default("active")

  // Relations
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([memberId, programId])
  @@map("program_enrollments")
}

model TaskStep {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId  String   @map("program_id") @db.Uuid
  stepNumber Int      @map("step_number")
  stepName   String   @map("step_name")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@map("task_steps")
}

model Task {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  programId        String   @map("program_id") @db.Uuid
  stepId           String?  @map("step_id") @db.Uuid
  dayNumber        Int      @map("day_number")
  title            String
  description      String?
  deliverables     String?
  contentUrl       String?  @map("content_url")
  basePoints       Int      @default(100) @map("base_points")
  proofType        String   @map("proof_type")
  estimatedMinutes Int      @default(15) @map("estimated_minutes")
  isMilestone      Boolean  @default(false) @map("is_milestone")
  milestoneLabel   String?  @map("milestone_label")
  bonusPoints      Int      @default(0) @map("bonus_points")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  program     Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  step        TaskStep?        @relation(fields: [stepId], references: [id])
  submissions TaskSubmission[]

  @@map("tasks")
}

model TaskSubmission {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId      String           @map("member_id") @db.Uuid
  taskId        String           @map("task_id") @db.Uuid
  responseValue String?          @map("response_value")
  proofUrl      String?          @map("proof_url")
  proofType     String?          @map("proof_type")
  status        SubmissionStatus @default(pending)
  reviewedBy    String?          @map("reviewed_by") @db.Uuid
  reviewedAt    DateTime?        @map("reviewed_at") @db.Timestamptz(6)
  feedback      String?
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer Admin? @relation("TaskReviewer", fields: [reviewedBy], references: [id])

  @@map("task_submissions")
}

model Podcast {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  audioUrl        String     @map("audio_url")
  thumbnailUrl    String?    @map("thumbnail_url")
  categoryId      String?    @map("category_id") @db.Uuid
  accessType      AccessType @default(free) @map("access_type")
  durationMinutes Int?       @map("duration_minutes")
  sortOrder       Int        @default(0) @map("sort_order")
  isPublished     Boolean    @default(false) @map("is_published")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  category Category?         @relation(fields: [categoryId], references: [id])
  progress PodcastProgress[]

  @@map("podcasts")
}

model PodcastProgress {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId            String   @map("member_id") @db.Uuid
  podcastId           String   @map("podcast_id") @db.Uuid
  listenPercentage    Int      @default(0) @map("listen_percentage")
  completed           Boolean  @default(false)
  lastPositionSeconds Int      @default(0) @map("last_position_seconds")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  podcast Podcast @relation(fields: [podcastId], references: [id], onDelete: Cascade)

  @@unique([memberId, podcastId])
  @@map("podcast_progress")
}

model Webinar {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  scheduledAt     DateTime      @map("scheduled_at") @db.Timestamptz(6)
  durationMinutes Int?          @map("duration_minutes")
  meetingUrl      String?       @map("meeting_url")
  recordingUrl    String?       @map("recording_url")
  status          WebinarStatus @default(scheduled)
  maxAttendees    Int?          @map("max_attendees")
  hostId          String?       @map("host_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  host          Admin?                @relation("WebinarHost", fields: [hostId], references: [id])
  registrations WebinarRegistration[]

  @@map("webinars")
}

model WebinarRegistration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId     String    @map("member_id") @db.Uuid
  webinarId    String    @map("webinar_id") @db.Uuid
  registeredAt DateTime  @default(now()) @map("registered_at") @db.Timestamptz(6)
  attended     Boolean   @default(false)
  joinTime     DateTime? @map("join_time") @db.Timestamptz(6)
  leaveTime    DateTime? @map("leave_time") @db.Timestamptz(6)

  // Relations
  member  Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  webinar Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([memberId, webinarId])
  @@map("webinar_registrations")
}

model Event {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  eventType       String   @map("event_type")
  eventDate       DateTime @map("event_date") @db.Timestamptz(6)
  location        String?
  isOnline        Boolean  @default(false) @map("is_online")
  registrationUrl String?  @map("registration_url")
  maxAttendees    Int?     @map("max_attendees")
  status          String   @default("scheduled")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  registrations EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId     String    @map("member_id") @db.Uuid
  eventId      String    @map("event_id") @db.Uuid
  registeredAt DateTime  @default(now()) @map("registered_at") @db.Timestamptz(6)
  attended     Boolean   @default(false)
  checkInTime  DateTime? @map("check_in_time") @db.Timestamptz(6)

  // Relations
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([memberId, eventId])
  @@map("event_registrations")
}

model Post {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  memberId       String   @map("member_id") @db.Uuid
  content        String
  postType       PostType @default(post) @map("post_type")
  mediaUrls      String[] @map("media_urls")
  isPinned       Boolean  @default(false) @map("is_pinned")
  isAnnouncement Boolean  @default(false) @map("is_announcement")
  likesCount     Int      @default(0) @map("likes_count")
  commentsCount  Int      @default(0) @map("comments_count")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
